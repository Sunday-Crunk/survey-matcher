NODE_ENV=development
HOST=127.0.0.1
PORT=4173
AUTH_SECRET=replace-with-a-long-random-secret
MATCHER_BOOTSTRAP_USERNAME=admin
MATCHER_BOOTSTRAP_DISPLAY_NAME=Admin
MATCHER_BOOTSTRAP_PASSWORD=replace-before-hosted-use

# Set this only when running against Postgres.
DATABASE_URL=postgresql://user:password@host:5432/database
PGSSLMODE=disable

# Use false for local HTTP Postgres smoke tests only. Omit on Render.
COOKIE_SECURE=false
