{
  "name": "survey-roster-matcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:design": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "dev:api": "node dist-server/matcher-web-server.cjs",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node20 --outdir=dist-electron --format=cjs --out-extension:.js=.cjs --external:electron --external:sql.js",
    "build:web": "tsc && vite build && esbuild server/matcher-web-server.ts --bundle --platform=node --target=node20 --outfile=dist-server/matcher-web-server.cjs --format=cjs --external:sql.js",
    "build:hosted": "tsc && vite build && esbuild server/matcher-postgres-server.ts --bundle --platform=node --target=node20 --outfile=dist-server/matcher-postgres-server.cjs --format=cjs --external:pg",
    "start:web": "node dist-server/matcher-web-server.cjs",
    "start:hosted": "node dist-server/matcher-postgres-server.cjs",
    "serve:web": "npm run build:web && npm run start:web",
    "migration:prepare": "node scripts/migrate-sqlite-to-postgres.mjs --source-root dev-data",
    "migration:prepare:web": "node scripts/migrate-sqlite-to-postgres.mjs --source-root web-data --out migration-output/web-data-preflight",
    "migration:apply": "node scripts/migrate-sqlite-to-postgres.mjs --source-root dev-data --apply",
    "migration:docker:up": "docker compose -f docker-compose.migration.yml up -d",
    "migration:docker:apply": "docker compose -f docker-compose.migration.yml exec -T postgres psql -U matcher -d matcher_migration -v ON_ERROR_STOP=1 -f /migration-output/web-data-preflight/apply.sql",
    "migration:docker:verify": "docker compose -f docker-compose.migration.yml exec -T postgres psql -U matcher -d matcher_migration -f /migration-output/web-data-preflight/verify.sql",
    "migration:docker:down": "docker compose -f docker-compose.migration.yml down -v",
    "hosted:create-user": "node scripts/create-hosted-user.mjs",
    "start": "electron .",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.13.0",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.surveyRosterMatcher",
    "productName": "Survey Roster Matcher",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/sql.js/dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "extraResources": [
      {
        "from": "seed-outputs",
        "to": "outputs",
        "filter": [
          "normalized_roster.csv",
          "deduped_survey_full_responses.csv",
          "match_candidates.csv",
          "matcher_review.sqlite"
        ]
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Survey Roster Matcher"
    }
  }
}
